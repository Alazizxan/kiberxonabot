generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum AchievementType {
  COURSE
  CHALLENGE
  LAB
  LEVEL
  SPECIAL
  EVENT
}

model AppConfig {
  // Singleton record. Its stable id makes the setting safe to read and update.
  id                String   @id @default("global")
  stableVersionOnly Boolean  @default(true)
  maintenanceMode   Boolean  @default(false)
  minSupportedVersion String @default("1.0.0")
  latestVersion     String   @default("1.0.0")
  apiVersion        String   @default("1.0.0")
  introVideoUrl     String?
  ctfIntroVideoUrl  String?
  labIntroVideoUrl  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model User {
  id           String @id @default(uuid())
  username     String @unique
  email        String @unique
  passwordHash String

  xp    Int @default(0)
  level Int @default(1)

  role Role @default(USER)

  isPremium    Boolean   @default(false)
  premiumUntil DateTime?

  progress         UserProgress[]
  userCourseAccess UserCourseAccess[] // 👈 ADD SHU
  hackerChats      HackerRoomChat[]

  cyberLabSessions CyberLabSession[]
  cyberLabReports  CyberLabReport[]
  trainSessions TrainSession[]

  challengeProgresses ChallengeProgress[]
  challengeSubmissions ChallengeFlagSubmission[]
  challengeComments ChallengeComment[]
  challengeCommentLikes ChallengeCommentLike[]
  challengeBadges ChallengeBadgeAward[]
  createdChallenges Challenge[] @relation("ChallengeAuthor")
  challengeBookmarks ChallengeBookmark[]
  challengeLikes ChallengeLike[]
  challengeObjectiveProgresses ChallengeObjectiveProgress[]
  challengeHintUnlocks ChallengeHintUnlock[]

  achievements UserAchievement[]

  phone         String?   @unique

  isVerified    Boolean   @default(false)

  telegramId    String?

  verifiedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String  @id @default(uuid())
  title       String
  description String
  thumbnail   String?
  isPremium   Boolean @default(false)
  xpReward    Int     @default(100)
  achievementId String?
  achievement Achievement? @relation(fields: [achievementId], references: [id], onDelete: SetNull)

  category String @default("cybersecurity")
  level    String @default("beginner") // beginner | junior | middle | senior

  PremiumCodes PremiumCode[]

  sections Section[]

  userCourseAccess UserCourseAccess[] // 👈 ADD SHU
  achievementAwards UserAchievement[]

  createdAt DateTime @default(now())
}

model Section {
  id    String @id @default(uuid())
  title String
  order Int

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  lessons Lesson[]
}

model Lesson {
  id          String  @id @default(uuid())
  title       String
  description String?

  type     String // TEXT | VIDEO | IMAGE
  content  String?
  videoUrl String?
  imageUrl String?

  xpReward Int   @default(10)
  order    Int
  quiz     Quiz?

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])
}

model UserProgress {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  courseId String
  lessonId String

  completed Boolean @default(false)
  xpEarned  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model PremiumCode {
  id   String @id @default(uuid())
  code String @unique

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  isUsed Boolean @default(false)

  createdAt DateTime @default(now())
}

model UserCourseAccess {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  type String // CODE | ADMIN

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model UserCourseCompletion {
  id       String @id @default(uuid())
  userId   String
  courseId String

  rewarded Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Quiz {
  id    String @id @default(uuid())
  title String

  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  questions Question[]

  createdAt DateTime @default(now())
}

model Question {
  id   String @id @default(uuid())
  text String

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])

  options Option[]
}

model Option {
  id        String  @id @default(uuid())
  text      String
  isCorrect Boolean @default(false)

  questionId String
  question   Question @relation(fields: [questionId], references: [id])
}

model QuizResult {
  id String @id @default(uuid())

  userId String
  quizId String

  score  Int
  passed Boolean

  createdAt DateTime @default(now())

  @@unique([userId, quizId])
}

model QuizAttempt {
  id String @id @default(uuid())

  userId String
  quizId String

  score  Int
  passed Boolean

  createdAt DateTime @default(now())
}

model HackerRoomMessage {
  id String @id @default(uuid())

  userId String

  role    String
  content String

  createdAt DateTime @default(now())
}

model HackerRoomChat {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  role String // USER | ASSISTANT

  message String @db.Text

  createdAt DateTime @default(now())
}

model Certificate {
  id String @id @default(uuid())

  userId   String
  courseId String

  verifyToken String @unique @default(uuid())

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model CyberLab {
  id String @id @default(uuid())

  code String @unique

  title       String
  description String @db.Text

  category   String
  difficulty String

  briefing String @db.Text

  hostname String @default("web-03")
  username String @default("analyst")

  xpReward Int @default(100)
  achievementId String?
  achievement Achievement? @relation(fields: [achievementId], references: [id], onDelete: SetNull)

  estimatedTime Int @default(30)

  fileSystem Json
  metadata   Json
  objectives Json
  flags      Json


  rules CyberLabRule[]

  files CyberLabFile[]

  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions CyberLabSession[]
  achievementAwards UserAchievement[]
}

model CyberLabSession {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  labId String
  lab   CyberLab @relation(fields: [labId], references: [id])

  hostname String
  username String

  currentDirectory String

  commandHistory   Json
  discoveredFlags  Json
  environmentState Json

  files CyberLabSessionFile[]

  startedAt DateTime @default(now())

  finishedAt DateTime?

  report CyberLabReport?
}

model CyberLabReport {
  id String @id @default(uuid())

  sessionId String          @unique
  session   CyberLabSession @relation(fields: [sessionId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  score Int
  grade String

  feedback Json

  xpEarned Int

  createdAt DateTime @default(now())
}

model CyberLabFile {
  id String @id @default(uuid())

  labId String
  lab CyberLab @relation(fields: [labId], references: [id], onDelete: Cascade)

  path String
  name String

  type String // FILE | DIRECTORY

  content String? @db.Text

  permissions String @default("rw-r--r--")

  owner String @default("root")
  group String @default("root")

  hidden Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([labId])
  @@index([path])
}

model CyberLabRule {
  id String @id @default(uuid())

  labId String
  lab CyberLab @relation(fields: [labId], references: [id], onDelete: Cascade)

  name String

  triggerType String
  triggerValue String

  rewardFlag String

  xpReward Int @default(0)

  createdAt DateTime @default(now())

  @@index([labId])
}


model CyberLabSessionFile {
  id String @id @default(uuid())

  sessionId String
  session CyberLabSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  path String
  name String

  type String // FILE | DIRECTORY

  content String? @db.Text

  permissions String @default("rw-r--r--")

  owner String @default("root")
  group String @default("root")

  hidden Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([path])
}


model CyberLabCompletion {
  id String @id @default(uuid())

  userId String
  labId String

  bestScore Int @default(0)
  attempts Int @default(0)

  xpRewarded Boolean @default(false)

  completedAt DateTime @default(now())

  @@unique([userId, labId])
}


model TrainSession {
  id String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  category String
  topic String

  explanation String?

  completed Boolean @default(false)
  exercises TrainExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainExercise {
  id String @id @default(uuid())

  sessionId String
  session TrainSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  step Int @default(1)

  type String

  content String @default("")

  expectedAnswer String?

  userAnswer String?

  correct Boolean?

  feedback String?

  createdAt DateTime @default(now())
}

model News {
  id          String   @id @default(uuid())

  title       String
  content     String   @db.Text

  imageUrl    String?

  category    NewsCategory @default(GENERAL)

  isPublished Boolean  @default(true)

  views       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum NewsCategory {
  GENERAL
  SECURITY
  PLATFORM
  COURSE
  LAB
  EVENT
  UPDATE
}

enum ChallengeDifficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum ChallengeContentType {
  MARKDOWN
  INFO
  WARNING
  SUCCESS
  QUOTE
  DIVIDER
  TABLE
  IMAGE
  VIDEO
  DOWNLOAD
  LINK
  CODE
}

enum ChallengeResourceType {
  PDF
  ZIP
  PCAP
  APK
  IMAGE
  VIDEO
  LINK
  DOC
  TXT
  LOG
  JSON
}

model Challenge {
  id String @id @default(uuid())
  slug String @unique
  title String
  summary String @db.Text
  description String @db.Text
  category String
  tags String[] @default([])
  difficulty ChallengeDifficulty @default(MEDIUM)
  coverUrl String?
  thumbnailUrl String?
  xpReward Int @default(100)
  achievementId String?
  achievement Achievement? @relation(fields: [achievementId], references: [id], onDelete: SetNull)
  estimatedTime Int @default(30)
  estimatedReads Int @default(0)
  estimatedDownloads Int @default(0)
  version String @default("1.0")
  language String @default("uz")
  shareTitle String?
  shareDescription String? @db.Text
  shareImage String?
  isPublished Boolean @default(false)
  publishedAt DateTime?
  views Int @default(0)

  badgeTitle String
  badgeDescription String @db.Text
  badgeIcon String

  createdById String
  createdBy User @relation("ChallengeAuthor", fields: [createdById], references: [id])

  contents ChallengeContent[]
  objectives ChallengeObjective[]
  resources ChallengeResource[]
  hints ChallengeHint[]
  badge ChallengeBadge?
  flags ChallengeFlag[]
  progresses ChallengeProgress[]
  submissions ChallengeFlagSubmission[]
  comments ChallengeComment[]
  badgeAwards ChallengeBadgeAward[]
  bookmarks ChallengeBookmark[]
  likes ChallengeLike[]
  achievementAwards UserAchievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, createdAt])
  @@index([category, difficulty])
}

model Achievement {
  id               String          @id @default(uuid())
  code             String          @unique
  type             AchievementType
  title            String
  subtitle         String?
  description      String          @db.Text
  badgeImage       String?
  rarity           String          @default("COMMON")
  xp               Int             @default(0)
  level            Int?
  shareTitle       String?
  shareDescription String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  userAchievements UserAchievement[]
  courses          Course[]
  challenges       Challenge[]
  labs             CyberLab[]

  @@index([type])
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  courseId      String?
  challengeId   String?
  labId         String?
  earnedAt      DateTime    @default(now())
  shareCount    Int         @default(0)
  downloadCount Int         @default(0)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Restrict)
  course      Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  challenge   Challenge?  @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  lab         CyberLab?   @relation(fields: [labId], references: [id], onDelete: SetNull)

  @@unique([userId, achievementId])
  @@index([userId, earnedAt])
  @@index([achievementId])
}

model ChallengeContent {
  id String @id @default(uuid())
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  type ChallengeContentType
  title String?
  body String? @db.Text
  url String?
  fileName String?
  order Int
  unlockAfterFlagOrder Int @default(0)
  createdAt DateTime @default(now())

  @@unique([challengeId, order])
  @@index([challengeId, unlockAfterFlagOrder])
}

model ChallengeObjective {
  id String @id @default(uuid())
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  title String
  description String? @db.Text
  order Int
  unlockAfterFlagOrder Int @default(0)
  progresses ChallengeObjectiveProgress[]
  @@unique([challengeId, order])
}

model ChallengeObjectiveProgress {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  objectiveId String
  objective ChallengeObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  @@unique([userId, objectiveId])
}

model ChallengeResource {
  id String @id @default(uuid())
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  title String
  type ChallengeResourceType
  url String
  fileName String?
  size Int?
  order Int
  unlockAfterFlagOrder Int @default(0)
  @@unique([challengeId, order])
}

model ChallengeHint {
  id String @id @default(uuid())
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  title String
  content String @db.Text
  order Int
  costXp Int @default(0)
  unlockAfterFlagOrder Int @default(0)
  unlocks ChallengeHintUnlock[]
  @@unique([challengeId, order])
}

model ChallengeHintUnlock {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  hintId String
  hint ChallengeHint @relation(fields: [hintId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())
  @@unique([userId, hintId])
}

model ChallengeBookmark {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, challengeId])
}

model ChallengeLike {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, challengeId])
}

model ChallengeBadge {
  id String @id @default(uuid())
  challengeId String @unique
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  title String
  icon String
  description String @db.Text
  color String @default("#22C55E")
  createdAt DateTime @default(now())
}

model ChallengeFlag {
  id String @id @default(uuid())
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  title String
  description String? @db.Text
  flagHash String
  order Int
  xpReward Int @default(0)
  successMessage String? @db.Text
  createdAt DateTime @default(now())

  submissions ChallengeFlagSubmission[]
  @@unique([challengeId, order])
}

model ChallengeProgress {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  solvedFlagCount Int @default(0)
  startedAt DateTime @default(now())
  solvedAt DateTime?
  xpAwarded Boolean @default(false)

  @@unique([userId, challengeId])
  @@index([challengeId, solvedAt])
}

model ChallengeFlagSubmission {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  flagId String
  flag ChallengeFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  submittedValue String @db.Text
  isCorrect Boolean
  createdAt DateTime @default(now())

  @@index([userId, challengeId, createdAt])
}

model ChallengeComment {
  id String @id @default(uuid())
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId String?
  parent ChallengeComment? @relation("ChallengeCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies ChallengeComment[] @relation("ChallengeCommentReplies")
  body String @db.Text
  isDeleted Boolean @default(false)
  isPinned Boolean @default(false)
  likes ChallengeCommentLike[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([challengeId, parentId, createdAt])
}

model ChallengeCommentLike {
  id String @id @default(uuid())
  commentId String
  comment ChallengeComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
}

model ChallengeBadgeAward {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, challengeId])
  @@index([userId, awardedAt])
}
